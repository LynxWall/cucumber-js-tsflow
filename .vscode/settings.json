{
	"typescript.tsdk": "node_modules\\typescript\\lib",
	"npm.packageManager": "yarn",
	"debug.javascript.autoAttachFilter": "disabled",
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnType": false,

	// Prettier configuration - Javascript and JSX Formatter
	"prettier.trailingComma": "none",
	"prettier.useTabs": true,
	"prettier.tabWidth": 2,
	"prettier.semi": true,
	"prettier.singleQuote": true,
	"prettier.printWidth": 120,
	"prettier.arrowParens": "avoid",
	"prettier.vueIndentScriptAndStyle": true,
	"prettier.htmlWhitespaceSensitivity": "ignore",
	"prettier.endOfLine": "crlf",

	// terminal integration for agents
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.shellIntegration.enabled": true,

	"files.exclude": {
		"**/.nyc_output": true,
		"**/.yarn": true,
		"**/coverage": true,
		"**/bin": false,
		"**/node_modules": true,
		"**/obj": true,
		"**/site": true,
		"**/wwwroot": true
	},

	// keep space befor function parens
	"typescript.format.insertSpaceBeforeFunctionParenthesis": true,
	"javascript.format.insertSpaceBeforeFunctionParenthesis": true,

	// File type editor settings
	"[feature]": {
		"editor.tabSize": 2
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[scss]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[vue]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2,
		"editor.tabCompletion": "onlySnippets"
	},
	"[xml]": {
		"editor.defaultFormatter": "mikeburgh.xml-format",
		"editor.tabSize": 2
	},
	"nugetpackagemanagergui.nuget.packageVersionsUrls": [
		"https://api.nuget.org/v3-flatcontainer/{{packageName}}/index.json",
		"https://proget.azdev.sis.jhu.edu/nuget/UISNuget/v3/flatcontainer/{{packageName}}/index.json"
	],
	"nugetpackagemanagergui.nuget.searchPackage.urls": [
		"https://azuresearch-usnc.nuget.org/query",
		"https://proget.azdev.sis.jhu.edu/nuget/UISNuget/v3/search"
	],
	"workbench.colorCustomizations": {
		"activityBar.activeBackground": "#00b88d",
		"activityBar.activeBorder": "#fa45d4",
		"activityBar.background": "#00b88d",
		"activityBar.foreground": "#e7e7e7",
		"activityBar.inactiveForeground": "#e7e7e799",
		"activityBarBadge.background": "#f8dfff",
		"activityBarBadge.foreground": "#15202b",
		"sash.hoverBorder": "#00b88d",
		"statusBar.background": "#008566",
		"statusBar.foreground": "#e7e7e7",
		"statusBarItem.hoverBackground": "#00b88d",
		"statusBarItem.remoteBackground": "#008566",
		"statusBarItem.remoteForeground": "#e7e7e7",
		"titleBar.activeBackground": "#008566",
		"titleBar.activeForeground": "#e7e7e7",
		"titleBar.inactiveBackground": "#00856699",
		"titleBar.inactiveForeground": "#e7e7e799",
		"commandCenter.border": "#e7e7e799"
	},
	"peacock.color": "#008566",
	"cucumberautocomplete.steps": ["cucumber-tsflow-specs/**/step_definitions/**/*.ts"],
	"cucumberautocomplete.strictGherkinCompletion": true,
	"cucumberautocomplete.syncfeatures": "cucumber-tsflow-specs/features/*feature",
	"cucumberautocomplete.strictGherkinValidation": false,
	"markdownlint.config": {
		"default": true,
		"MD003": { "style": "atx" },
		"MD007": { "indent": 2 },
		"MD032": false,
		"MD022": false,
		"MD024": false,
		"no-hard-tabs": false
	}
}
