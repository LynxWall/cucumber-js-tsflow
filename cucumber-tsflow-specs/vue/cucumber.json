{
	"esvue": {
		"transpiler": "es-vue",
		"paths": ["../features/**/*.feature"],
		"require": ["./src/step_definitions/**/*.ts"],
		"format": [["behave", "../reports/esvue.json"], "html:../reports/esvue.html", "junitbamboo:../reports/esvue.xml"],
		"tags": "@vue",
		"parallel": 0,
		"parallelLoad": false
	},
	"tsvue": {
		"transpiler": "ts-vue",
		"paths": ["../features/**/*.feature"],
		"require": ["./src/step_definitions/**/*.ts"],
		"format": ["behave:../reports/tsvue.json", "html:../reports/tsvue.html", "junitbamboo:../reports/tsvue.xml"],
		"tags": "@vue",
		"parallel": 0,
		"parallelLoad": true
	}
}
